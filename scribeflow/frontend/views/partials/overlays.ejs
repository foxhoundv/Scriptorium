<!-- APP SETTINGS PANEL -->
<div id="admin-overlay">
  <div id="admin-panel">
    <div id="admin-header">
      <h2>App Settings</h2>
      <button id="admin-close">✕</button>
    </div>
    <div id="admin-body">
      <div id="admin-nav">
        <div class="an-item active" data-asection="multiuser">👥 Multi-User</div>
        <div class="an-item" id="an-users" data-asection="users" style="display:none">🛡 Users</div>
      </div>
      <div id="admin-content">

        <!-- MULTI-USER SECTION -->
        <div class="admin-section active" id="asection-multiuser">
          <h3>Multi-User Mode</h3>
          <div class="mu-status-row"><span class="mu-badge-on" id="mu-status-badge">● Multi-user active</span></div>
          <p style="font-size:13px;color:var(--text3);line-height:1.7;margin-top:12px;">
            Multi-user mode is controlled by the <code>AUTH_ENABLED</code> environment variable in your
            <code>docker-compose.yml</code>. Restart the container after changing it.
          </p>
          <p style="font-size:13px;color:var(--text3);line-height:1.7;margin-top:8px;">
            Use the <strong>Users</strong> tab to create and manage team accounts.
          </p>
        </div>

        <!-- USER MANAGEMENT SECTION -->
        <div class="admin-section" id="asection-users">
          <h3>User Management</h3>

          <!-- Create user form -->
          <div id="create-user-form" style="background:var(--bg2);border-radius:8px;padding:14px;margin-bottom:20px;">
            <div style="font-weight:600;font-size:13px;margin-bottom:10px;">Create New User</div>
            <div class="um-form-row">
              <input type="text" id="cu-username" placeholder="Username" class="settings-input" style="flex:1;min-width:120px">
              <input type="text" id="cu-displayname" placeholder="Display Name" class="settings-input" style="flex:1;min-width:120px">
            </div>
            <div class="um-form-row" style="margin-top:8px;">
              <input type="password" id="cu-password" placeholder="Password" class="settings-input" style="flex:1;min-width:120px">
              <select id="cu-role" class="settings-input" style="flex:0 0 90px">
                <option value="user">User</option>
                <option value="admin">Admin</option>
              </select>
              <button id="cu-create-btn" class="settings-btn-primary">Create</button>
            </div>
            <p id="cu-message" style="font-size:12px;margin-top:6px;display:none"></p>
          </div>

          <!-- Active users -->
          <div class="um-section">
            <div class="um-section-head">Active Users</div>
            <div id="users-active-list"><span class="no-users">Loading…</span></div>
          </div>

          <!-- Suspended users -->
          <div class="um-section">
            <div class="um-section-head">Suspended</div>
            <div id="users-suspended-list"><span class="no-users">None</span></div>
          </div>
        </div>

      </div><!-- #admin-content -->
    </div><!-- #admin-body -->
  </div><!-- #admin-panel -->
</div><!-- #admin-overlay -->

<!-- PROJECT SHARE MODAL -->
<div id="share-overlay">
  <div id="share-panel">
    <div id="share-header">
      <h3>Share Project</h3>
      <button id="share-close">✕</button>
    </div>
    <div id="share-body">
      <div class="share-owner-row">
        <span class="share-owner-label">Owner</span>
        <span id="share-owner-name" class="share-owner-name"></span>
        <button id="share-transfer-btn" style="display:none">Transfer Ownership</button>
      </div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--text3);margin-bottom:8px;">Shared With</div>
      <div id="share-users-list"></div>
      <div id="share-add-row">
        <select id="share-user-select"><option value="">— Add a user —</option></select>
        <select id="share-role-select">
          <option value="editor">Editor</option>
          <option value="viewer">Viewer</option>
        </select>
        <button id="share-add-btn">Add</button>
      </div>
    </div>
  </div>
</div>

<!-- AUTH LOGIN SCREEN -->
<div id="auth-overlay">
  <div class="auth-card">
    <div class="auth-logo">ScribeFlow</div>
    <p class="auth-tagline">Your self-hosted writing workspace</p>
    <div class="auth-divider"></div>
    <form class="auth-login-form" id="login-form" onsubmit="return false">
      <input type="text"     id="login-username" class="auth-input" placeholder="Username" autocomplete="username" required>
      <input type="password" id="login-password" class="auth-input" placeholder="Password" autocomplete="current-password" required>
      <button type="submit"  id="login-btn"      class="auth-submit">Sign In</button>
    </form>
    <p id="auth-error-msg" class="auth-error" style="display:none"></p>
  </div>
</div>
